{
  "name": "ai4js",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript AI/ML framework",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:e2e": "playwright test",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "build": "tsc && node esbuild.config.js",
    "typecheck": "tsc --noEmit",
    "server": "vite --port 3000"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ndarray": "^1.0.19"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.14",
    "@types/ndarray": "^1.0.14",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.22.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.13"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "diagnostics": false
        }
      ]
    }
  }
}
